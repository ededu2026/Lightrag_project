    <node id="Partial (Tier 1)">
      <data key="d0">Partial (Tier 1)</data>
      <data key="d1">concept</data>
      <data key="d2">An organization can choose to use the Tiers to inform its Current and Target Profiles, indicating the Partial Tier describes informal responses to cybersecurity risks.</data>
      <data key="d3">chunk-1a1497d01e433b4c62c0be4ed37b11e3</data>
      <data key="d4">parsed_data/NIST.CSWP.29.md</data>
