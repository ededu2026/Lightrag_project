    <node id="Informative References">
      <data key="d0">Informative References</data>
      <data key="d1">concept</data>
      <data key="d2">Informative References are provided to complement the NIST Cybersecurity Framework (CSF) for achieving outcomes through external resources.&lt;SEP&gt;References that indicate relationships between different cybersecurity standards, guidelines, and regulations.</data>
