    <node id="Risk Informed (Tier 2)">
      <data key="d0">Risk Informed (Tier 2)</data>
      <data key="d1">concept</data>
      <data key="d2">The Risk Informed Tier represents a more agile approach in managing cybersecurity risks compared to other tiers.</data>
      <data key="d3">chunk-1a1497d01e433b4c62c0be4ed37b11e3</data>
      <data key="d4">parsed_data/NIST.CSWP.29.md</data>
      <data key="d5">1773879942</data>
